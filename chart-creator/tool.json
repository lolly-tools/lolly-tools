{
  "id": "chart-creator",
  "name": "Chart Creator",
  "description": "On-brand charts from your data — bar, donut, pie or stacked.",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["chart", "data", "visualization", "bar", "pie", "donut", "infographic", "svg"],
  "featured": {
    "order": 5,
    "blurb": "On-brand charts from your data, any shape"
  },
  "examples": [
    {
      "label": "Donut with legend",
      "values": {
        "chartType": "donut", "heading": "Where the budget goes", "showLegend": true, "background": "#ffffff", "color": "#1a1a2e",
        "data": [
          { "label": "Cloud", "value": "38", "color": "#0f766e" },
          { "label": "Hardware", "value": "24", "color": "#f2a65a" },
          { "label": "Services", "value": "22", "color": "#334155" },
          { "label": "Support", "value": "16", "color": "#93c5fd" }
        ]
      }
    },
    {
      "label": "Ranked bars",
      "values": {
        "chartType": "horizontal-bar", "heading": "Top regions", "cornerRadius": 6, "background": "#faf7f2", "color": "#1a1a2e", "width": 1280, "height": 800,
        "data": [
          { "label": "EMEA", "value": "44", "color": "#134e4a" },
          { "label": "Americas", "value": "37", "color": "#0f766e" },
          { "label": "APAC", "value": "29", "color": "#14b8a6" },
          { "label": "LATAM", "value": "18", "color": "#5eead4" }
        ]
      }
    },
    {
      "label": "Dark pie, percent labels",
      "values": {
        "chartType": "pie", "valueFormat": "percent", "background": "#1a1a2e", "color": "#f5efe6", "strokeWidth": 4, "strokeColor": "#1a1a2e",
        "data": [
          { "label": "Organic", "value": "52", "color": "#f2a65a" },
          { "label": "Referral", "value": "31", "color": "#ffd3bd" },
          { "label": "Paid", "value": "17", "color": "#7c2d12" }
        ]
      }
    },
    {
      "label": "Minimal columns",
      "values": {
        "chartType": "vertical-bar", "dataLabels": false, "cornerRadius": 8, "background": "#ffffff", "color": "#334155",
        "data": [
          { "label": "Q1", "value": "42", "color": "#cbd5e1" },
          { "label": "Q2", "value": "49", "color": "#94a3b8" },
          { "label": "Q3", "value": "55", "color": "#64748b" },
          { "label": "Q4", "value": "61", "color": "#334155" }
        ]
      }
    }
  ],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "svg", "emf", "pdf",  "pdf-cmyk", "cmyk-tiff", "tiff", "pptx", "webp", "csv", "md"],
    "actions": ["copy", "download", "save"],
    "transparentBg": true
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "chartType", "urlKey": "ct",
      "label": "Chart type",
      "type": "select",
      "default": "donut",
      "options": [
        { "value": "vertical-bar",   "label": "Vertical bars" },
        { "value": "horizontal-bar", "label": "Horizontal bars" },
        { "value": "donut",          "label": "Donut" },
        { "value": "pie",            "label": "Pie" },
        { "value": "stacked",        "label": "Stacked bar" }
      ]
    },
    {
      "id": "donutRadius", "urlKey": "dr",
      "label": "Donut radius",
      "type": "number",
      "display": "slider",
      "min": 0.10,
      "max": 0.90,
      "step": 0.01,
      "default": 0.44,
      "showIf": { "chartType": "donut" }
    },
    {
      "id": "stackMax", "urlKey": "sm",
      "label": "Scale max",
      "type": "number",
      "default": 0,
      "min": 0,
      "placeholder": "0 = fit to total",
      "help": "Leave 0 to fit the bar to your values’ total (a composite). Set a number to scale the composite against a fixed maximum — the bar fills that share and leaves an empty remainder.",
      "showIf": { "chartType": "stacked" }
    },
    {
      "id": "sliceGap", "urlKey": "sg",
      "label": "Gap between slices",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 40,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Spacing between slices, in pixels at the outer edge. 0 = slices touch."
    },
    {
      "id": "cornerRadius", "urlKey": "cr",
      "label": "Corner radius",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Rounds the corners of each slice. Clamped automatically for thin or narrow slices."
    },
    {
      "id": "strokeWidth", "urlKey": "ow",
      "label": "Outline width",
      "section": "Slices",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 24,
      "step": 1,
      "showIf": { "chartType": ["pie", "donut"] },
      "help": "Outline around each slice. 0 = no outline."
    },
    {
      "id": "strokeColor", "urlKey": "oc",
      "label": "Outline color",
      "section": "Slices",
      "type": "color",
      "default": "{color.semantic.surface}",
      "showIf": { "chartType": ["pie", "donut"] }
    },
    {
      "id": "heading", "urlKey": "t",
      "label": "Title",
      "type": "text",
      "default": "",
      "placeholder": "Chart title"
    },
    {
      "id": "subheading", "urlKey": "st",
      "label": "Subtitle / source",
      "type": "text",
      "default": "",
      "placeholder": "Optional subtitle or data source"
    },
    {
      "id": "color", "urlKey": "tc",
      "label": "Text color",
      "type": "color",
      "default": "{color.semantic.text}"
    },
    {
      "id": "background", "urlKey": "bg",
      "label": "Background",
      "type": "color",
      "default": "{color.semantic.surface}"
    },
    {
      "id": "showLegend", "urlKey": "lg",
      "label": "Show legend",
      "section": "Legend",
      "type": "boolean",
      "default": false
    },
    {
      "id": "legendPosition", "urlKey": "lp",
      "label": "Position",
      "section": "Legend",
      "type": "select",
      "default": "bottom",
      "options": [
        { "value": "bottom", "label": "Bottom" },
        { "value": "top", "label": "Top" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendDotShape", "urlKey": "ld",
      "label": "Dot shape",
      "section": "Legend",
      "type": "select",
      "default": "circle",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "circle", "label": "Circle" }
      ],
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendSize", "urlKey": "ls",
      "label": "Text size",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 22,
      "min": 8,
      "max": 48,
      "step": 1,
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendFontWeight", "urlKey": "lf",
      "label": "Font weight",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 500,
      "min": 100,
      "max": 900,
      "step": 100,
      "showIf": { "showLegend": true }
    },
    {
      "id": "legendMaxChars", "urlKey": "lm",
      "label": "Max label length",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "showIf": { "showLegend": true },
      "help": "Characters shown before a legend label is shortened with “…”. 0 = automatic."
    },
    {
      "id": "legendWidth", "urlKey": "lw",
      "label": "Legend width %",
      "section": "Legend",
      "type": "number",
      "display": "slider",
      "default": 40,
      "min": 15,
      "max": 65,
      "step": 1,
      "showIf": { "showLegend": true }
    },
    {
      "id": "showLabels", "urlKey": "sl",
      "label": "Show labels",
      "section": "Labels",
      "type": "boolean",
      "default": true
    },
    {
      "id": "labelSize", "urlKey": "lbs",
      "label": "Text size",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 44,
      "min": 10,
      "max": 48,
      "step": 1
    },
    {
      "id": "labelWeight", "urlKey": "lbw",
      "label": "Font weight",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 600,
      "min": 100,
      "max": 900,
      "step": 100
    },
    {
      "id": "labelMaxChars", "urlKey": "lbm",
      "label": "Max label length",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 60,
      "step": 1,
      "help": "Characters shown before a label is shortened with “…”. 0 = automatic."
    },
    {
      "id": "labelPosition", "urlKey": "lbp",
      "label": "Position",
      "section": "Labels",
      "type": "select",
      "default": "inside",
      "options": [
        { "value": "inside",  "label": "Inside" },
        { "value": "outside", "label": "Outside" }
      ]
    },
    {
      "id": "labelAlign", "urlKey": "lba",
      "label": "Align",
      "section": "Labels",
      "type": "select",
      "default": "bottom",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "id": "labelOffset",
      "label": "Offset",
      "section": "Labels",
      "type": "vector",
      "fields": [
        { "id": "x", "label": "X", "min": -100, "max": 100, "step": 1, "default": 0 },
        { "id": "y", "label": "Y", "min": -100, "max": 100, "step": 1, "default": 0 }
      ]
    },
    {
      "id": "labelGap", "urlKey": "lbg",
      "label": "Outside gap",
      "section": "Labels",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 120,
      "step": 1
    },
    {
      "id": "dataLabels", "urlKey": "dv",
      "label": "Show values",
      "section": "Value",
      "type": "boolean",
      "default": true
    },
    {
      "id": "valueSize", "urlKey": "vs",
      "label": "Text size",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 51,
      "min": 8,
      "max": 96,
      "step": 1
    },
    {
      "id": "valueWeight", "urlKey": "vw",
      "label": "Font weight",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 500,
      "min": 100,
      "max": 900,
      "step": 100
    },
    {
      "id": "valuePosition", "urlKey": "vp",
      "label": "Position",
      "section": "Value",
      "type": "select",
      "default": "inside",
      "options": [
        { "value": "inside",  "label": "Inside" },
        { "value": "outside", "label": "Outside" }
      ]
    },
    {
      "id": "valueAlign", "urlKey": "va",
      "label": "Align",
      "section": "Value",
      "type": "select",
      "default": "center",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "id": "valueOffset",
      "label": "Offset",
      "section": "Value",
      "type": "vector",
      "fields": [
        { "id": "x", "label": "X", "min": -100, "max": 100, "step": 1, "default": 0 },
        { "id": "y", "label": "Y", "min": -100, "max": 100, "step": 1, "default": 0 }
      ]
    },
    {
      "id": "valueGap", "urlKey": "vg",
      "label": "Outside gap",
      "section": "Value",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 120,
      "step": 1
    },
    {
      "id": "valueFormat", "urlKey": "vf",
      "label": "Number format",
      "section": "Value",
      "type": "select",
      "default": "auto",
      "options": [
        { "value": "auto",    "label": "Auto" },
        { "value": "value",   "label": "Original number" },
        { "value": "percent", "label": "Percentage" }
      ]
    },
    {
      "id": "data", "urlKey": "d",
      "label": "Data",
      "type": "blocks",
      "importData": { "formats": ["csv", "json"] },
      "fields": [
        { "id": "label", "urlKey": "l", "label": "Label", "placeholder": "Label" },
        { "id": "value", "urlKey": "v", "label": "Value", "placeholder": "0" },
        { "id": "color", "urlKey": "c", "label": "Color", "type": "color", "placeholder": "#30ba78" }
      ],
      "default": [
        { "label": "Public cloud", "value": "38", "color": "#008657" },
        { "label": "Data center",  "value": "31", "color": "#2453ff" },
        { "label": "Edge sites",   "value": "19", "color": "#fe7c3f" },
        { "label": "Air-gapped",   "value": "12", "color": "#00bda7" }
      ]
    },
    { "id": "width",  "label": "Width",  "type": "number", "default": 1080, "min": 100, "max": 8000, "group": "export" },
    { "id": "height", "label": "Height", "type": "number", "default": 1080, "min": 100, "max": 8000, "group": "export" }
  ]
}
