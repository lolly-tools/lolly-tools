        {
          "value": "linear",
          "label": "Straight"
        },
        {
          "value": "monotone",
          "label": "Smooth (monotone)"
        },
        {
          "value": "natural",
          "label": "Smooth (natural)"
        },
        {
          "value": "catmullRom",
          "label": "Smooth (Catmull–Rom)"
        },
        {
          "value": "cardinal",
          "label": "Smooth (cardinal)"
        },
        {
          "value": "basis",
          "label": "Smooth (basis)"
        },
        {
          "value": "step",
          "label": "Step (mid)"
        },
        {
          "value": "stepBefore",
          "label": "Step (before)"
        },
        {
          "value": "stepAfter",
          "label": "Step (after)"
        },
        {
          "value": "bumpX",
          "label": "Bump"
        }
