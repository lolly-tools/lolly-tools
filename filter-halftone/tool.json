{
  "id": "filter-halftone",
  "name": "Filter: Halftone",
  "description": "Vector halftone from any photo — dots sized by brightness.",
  "a11yLabel": "Halftone rendering of the chosen image as a grid of single-colour dots",
  "version": "1.1.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["halftone", "dots", "photo", "filter", "effect", "newspaper", "comic", "vector", "image"],
  "examples": [
    { "label": "Newsprint", "values": { "colorSource": "solid", "fgColor": "#1a1a2e", "bgColor": "#f5efe6", "gridSize": 34, "dither": "floyd" } },
    { "label": "Comic dots", "values": { "colorSource": "solid", "fgColor": "#7c2d12", "bgColor": "#ffd3bd", "gridSize": 18, "dotScale": 1.3 } },
    { "label": "Diamond weave", "values": { "shape": "diamond", "gridSize": 28, "dotScale": 1.15 } },
    { "label": "Coarse squares", "values": { "shape": "square", "colorSource": "solid", "fgColor": "#f5efe6", "bgColor": "#0b1021", "gridSize": 10, "invert": true } }
  ],
  "render": {
    "width": 1000,
    "height": 1000,
    "formats": ["svg", "pdf", "pdf-cmyk", "emf", "png", "webp", "avif", "gif", "apng", "webm", "mp4"],
    "actions": ["copy", "download", "save"],
    "video": { "wait": 0, "duration": 5 },
    "transparentBg": false,
    "convertPaths": false
  },
  "inputs": [
    {
      "id": "image",
      "label": "Image",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "help": "Pick a photo or upload your own. It's processed on your device — the pixels never leave the browser."
    },
    {
      "id": "gridSize",
      "label": "Grid size",
      "type": "number",
      "display": "slider",
      "default": 24,
      "min": 1,
      "max": 70,
      "step": 1,
      "help": "Spacing between dots. Smaller = finer detail and more dots; larger = a bolder, coarser screen."
    },
    {
      "id": "dotScale",
      "label": "Dot size",
      "type": "number",
      "display": "slider",
      "default": 1,
      "min": 0.2,
      "max": 3,
      "step": 0.02,
      "help": "Scales every dot. Below 1 opens up the screen; above 1 fattens the dots so darks fill in."
    },
    {
      "id": "shape",
      "label": "Dot shape",
      "type": "select",
      "default": "circle",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" },
        { "value": "diamond", "label": "Diamond" }
      ]
    },
    {
      "id": "colorSource",
      "label": "Colour source",
      "type": "select",
      "default": "image",
      "options": [
        { "value": "image", "label": "From image" },
        { "value": "solid", "label": "Solid colour" }
      ],
      "help": "Colour the dots from the photo underneath, or a single ink."
    },
    {
      "id": "colorLevels",
      "label": "Colour levels",
      "type": "select",
      "default": "0",
      "showIf": { "colorSource": "image" },
      "options": [
        { "value": "0", "label": "Full colour" },
        { "value": "8", "label": "8 levels" },
        { "value": "6", "label": "6 levels" },
        { "value": "4", "label": "4 levels" },
        { "value": "3", "label": "3 levels" },
        { "value": "2", "label": "2 levels" }
      ],
      "help": "Reduce the dot colours to a limited palette (levels per channel). Full keeps the photo's colours."
    },
    {
      "id": "fgColor",
      "label": "Dot colour",
      "type": "color",
      "default": "{color.semantic.text}",
      "showIf": { "colorSource": "solid" },
      "help": "Dot colour when Colour source is Solid."
    },
    {
      "id": "bgColor",
      "label": "Background",
      "type": "color",
      "default": "{color.semantic.surface}",
      "help": "Fill behind the dots. Turn on “No BG” in the export options for a transparent background instead."
    },
    {
      "id": "invert",
      "label": "Invert",
      "type": "boolean",
      "default": false,
      "help": "Grow dots for the light areas instead of the dark — ideal for a light colour on a dark background."
    },
    {
      "id": "fit",
      "label": "Image fit",
      "type": "select",
      "default": "contain",
      "options": [
        { "value": "contain", "label": "Contain (whole image)" },
        { "value": "cover", "label": "Cover (fill, crop edges)" }
      ]
    },
    {
      "id": "brightness",
      "label": "Brightness",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -100,
      "max": 100,
      "step": 1
    },
    {
      "id": "gamma",
      "label": "Gamma",
      "type": "number",
      "display": "slider",
      "default": 1,
      "min": 0.1,
      "max": 3,
      "step": 0.1,
      "help": "Mid-tone weighting. Below 1 darkens mid-tones (denser dots); above 1 lightens them."
    },
    {
      "id": "smoothing",
      "label": "Smoothing",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 5,
      "step": 0.5,
      "help": "Softens the dot grid by blurring neighbouring cells. Tames noisy photos."
    },
    {
      "id": "dither",
      "label": "Texture",
      "type": "select",
      "default": "none",
      "options": [
        { "value": "none", "label": "Smooth (none)" },
        { "value": "floyd", "label": "Diffused (Floyd–Steinberg)" },
        { "value": "ordered", "label": "Patterned (ordered)" },
        { "value": "noise", "label": "Grainy (noise)" }
      ],
      "help": "Adds a newspaper-style 1-bit texture by snapping cells to full or empty dots."
    },
    {
      "id": "contrast",
      "label": "Contrast",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 10,
      "min": -100,
      "max": 100,
      "step": 1
    },
    {
      "id": "hue",
      "label": "Hue",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -180,
      "max": 180,
      "step": 1,
      "help": "Rotate every colour around the wheel."
    },
    {
      "id": "saturation",
      "label": "Saturation",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 1,
      "help": "0 = greyscale · 100 = original · 200 = vivid."
    },
    {
      "id": "lightness",
      "label": "Lightness",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -100,
      "max": 100,
      "step": 1,
      "help": "Lift toward white or sink toward black."
    },
    {
      "id": "treatmentColor",
      "label": "Colour treatment",
      "section": "Colour",
      "type": "color",
      "default": "",
      "help": "Blend a colour over the result. Leave empty for none."
    },
    {
      "id": "blendMode",
      "label": "Blend mode",
      "section": "Colour",
      "type": "select",
      "default": "multiply",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "screen", "label": "Screen" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "darken", "label": "Darken" },
        { "value": "lighten", "label": "Lighten" },
        { "value": "color-dodge", "label": "Colour dodge" },
        { "value": "color-burn", "label": "Colour burn" },
        { "value": "hard-light", "label": "Hard light" },
        { "value": "soft-light", "label": "Soft light" },
        { "value": "difference", "label": "Difference" },
        { "value": "exclusion", "label": "Exclusion" },
        { "value": "hue", "label": "Hue" },
        { "value": "saturation", "label": "Saturation" },
        { "value": "color", "label": "Colour" },
        { "value": "luminosity", "label": "Luminosity" }
      ],
      "help": "How the treatment colour mixes with the image."
    },
    {
      "id": "treatmentIntensity",
      "label": "Intensity",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "Opacity of the colour overlay."
    },
    {
      "id": "noFilter",
      "label": "No filter (show raw)",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "Show the original photo or live camera feed untouched — handy for placing just a logo / lower-third over the raw footage."
    },
    {
      "id": "showLogo",
      "label": "SUSE logo overlay",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "Overlay the SUSE logo on the result. Off by default."
    },
    {
      "id": "logoPosition",
      "label": "Logo position",
      "section": "Overlay",
      "type": "select",
      "default": "top-right",
      "showIf": { "showLogo": true },
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-right", "label": "Top right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "top", "label": "Top centre" },
        { "value": "bottom", "label": "Bottom centre" },
        { "value": "center", "label": "Centre" },
        { "value": "full", "label": "Full (watermark)" }
      ]
    },
    {
      "id": "logoStyle",
      "label": "Logo colour",
      "section": "Overlay",
      "type": "select",
      "default": "white",
      "showIf": { "showLogo": true },
      "options": [
        { "value": "white", "label": "White" },
        { "value": "green", "label": "Green" },
        { "value": "black", "label": "Black" }
      ],
      "help": "White and green read on dark or busy footage; black suits light backgrounds."
    },
    {
      "id": "logoScale",
      "label": "Logo size",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "default": 1,
      "min": 0.25,
      "max": 3,
      "step": 0.05,
      "showIf": { "showLogo": true },
      "help": "Scale the logo up or down."
    },
    {
      "id": "lowerThird",
      "label": "Lower-third name card",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "A gently-animated name card that draws in over the footage. Uses your profile name & headshot."
    },
    {
      "id": "ltTheme",
      "label": "Card style",
      "section": "Overlay",
      "type": "select",
      "default": "bar",
      "showIf": { "lowerThird": true },
      "options": [
        { "value": "bar", "label": "SUSE brand bar" },
        { "value": "minimal", "label": "Minimal" },
        { "value": "glass", "label": "Glass" }
      ]
    },
    {
      "id": "ltPosition",
      "label": "Card position",
      "section": "Overlay",
      "type": "select",
      "default": "left",
      "showIf": { "lowerThird": true },
      "options": [
        { "value": "left", "label": "Bottom left" },
        { "value": "center", "label": "Bottom centre" },
        { "value": "right", "label": "Bottom right" }
      ]
    },
    {
      "id": "firstname",
      "label": "First name",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "bindToProfile": "firstname",
      "showIf": { "lowerThird": true }
    },
    {
      "id": "lastname",
      "label": "Last name",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "bindToProfile": "lastname",
      "showIf": { "lowerThird": true }
    },
    {
      "id": "title",
      "label": "Role / subtitle",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "showIf": { "lowerThird": true },
      "help": "Optional line below the name — e.g. a role or event."
    },
    {
      "id": "nameWeight",
      "label": "Name weight",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "showIf": { "lowerThird": true },
      "help": "Font weight of the name line (100 Thin → 900 Black)."
    },
    {
      "id": "subtitleWeight",
      "label": "Subtitle weight",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "showIf": { "lowerThird": true },
      "help": "Font weight of the role / subtitle line (100 Thin → 900 Black)."
    },
    {
      "id": "ltHeadshot",
      "label": "Headshot (optional)",
      "section": "Overlay",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "showIf": { "lowerThird": true },
      "help": "Defaults to your profile headshot. Pick or upload another to override."
    }
  ],
  "hooks": {
    "onInit": true,
    "onInput": true,
    "onFrame": true,
    "beforeExport": true
  }
}
