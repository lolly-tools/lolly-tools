{
  "id": "filter-scanline",
  "name": "Filter: Scanline",
  "description": "Horizontal 'infinity lines' scanline vector effect from any photo",
  "a11yLabel": "Scanline rendering of the chosen image in brand tones",
  "version": "1.1.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["scanline", "crt", "pixel", "retro", "posterize", "halftone", "image", "filter", "effect"],
  "render": {
    "width": 1000,
    "height": 1000,
    "formats": ["svg", "png", "webp", "avif", "gif", "apng", "webm", "mp4"],
    "actions": ["copy", "download", "save"],
    "video": { "wait": 0, "duration": 5 },
    "convertPaths": false
  },
  "inputs": [
    {
      "id": "image",
      "label": "Image",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "help": "Pick a photo or upload your own. It's processed on your device — the pixels never leave the browser."
    },
    {
      "id": "lineSize",
      "label": "Line height",
      "type": "number",
      "display": "slider",
      "default": 14,
      "min": 1,
      "max": 48,
      "step": 1,
      "help": "Height of each scanline and the size of each cell, so smaller means thinner lines and finer detail."
    },
    {
      "id": "gapSize",
      "label": "Gap height",
      "type": "number",
      "display": "slider",
      "default": 12,
      "min": 0,
      "max": 48,
      "step": 1,
      "help": "Size of the blank gap below each scanline, relative to the line. Larger = thinner lines with more space between them; 0 makes a solid image with no gaps. Doesn't change the detail or position of the image."
    },
    {
      "id": "separatePixels",
      "label": "Separate pixels",
      "type": "boolean",
      "default": false,
      "help": "Add a gap between cells too, so each one is a distinct square — an LED/pixel-matrix look instead of solid scanline bars."
    },
    {
      "id": "everyLine",
      "label": "Fill every line",
      "type": "boolean",
      "default": false,
      "help": "Draw every line with no gaps — the same as setting the gap height to zero. Off = classic scanlines; on = a solid posterised image."
    },
    {
      "id": "fit",
      "label": "Image fit",
      "type": "select",
      "default": "cover",
      "options": [
        { "value": "contain", "label": "Contain (whole image)" },
        { "value": "cover", "label": "Cover (fill, crop edges)" }
      ]
    },
    {
      "id": "highlight",
      "label": "Highlight",
      "type": "color",
      "default": "#ffffff",
      "help": "Brightest tone."
    },
    {
      "id": "light",
      "label": "Light",
      "type": "color",
      "default": "#bff1ea"
    },
    {
      "id": "mid",
      "label": "Mid",
      "type": "color",
      "default": "#008878"
    },
    {
      "id": "shade",
      "label": "Shade",
      "type": "color",
      "default": "#01564a"
    },
    {
      "id": "shadow",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "help": "Darkest tone."
    },
    {
      "id": "background",
      "label": "Background",
      "type": "color",
      "default": "",
      "help": "Fills the blank lines and gaps. Leave empty for a transparent background (PNG/WebP/AVIF/SVG keep the transparency)."
    },
    {
      "id": "brightness",
      "label": "Brightness",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -100,
      "max": 100,
      "step": 1
    },
    {
      "id": "contrast",
      "label": "Contrast",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 10,
      "min": -100,
      "max": 100,
      "step": 1
    },
    {
      "id": "hue",
      "label": "Hue",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -180,
      "max": 180,
      "step": 1,
      "help": "Rotate every colour around the wheel."
    },
    {
      "id": "saturation",
      "label": "Saturation",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 1,
      "help": "0 = greyscale · 100 = original · 200 = vivid."
    },
    {
      "id": "lightness",
      "label": "Lightness",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -100,
      "max": 100,
      "step": 1,
      "help": "Lift toward white or sink toward black."
    },
    {
      "id": "treatmentColor",
      "label": "Colour treatment",
      "section": "Colour",
      "type": "color",
      "default": "",
      "help": "Blend a colour over the result. Leave empty for none."
    },
    {
      "id": "blendMode",
      "label": "Blend mode",
      "section": "Colour",
      "type": "select",
      "default": "multiply",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "screen", "label": "Screen" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "darken", "label": "Darken" },
        { "value": "lighten", "label": "Lighten" },
        { "value": "color-dodge", "label": "Colour dodge" },
        { "value": "color-burn", "label": "Colour burn" },
        { "value": "hard-light", "label": "Hard light" },
        { "value": "soft-light", "label": "Soft light" },
        { "value": "difference", "label": "Difference" },
        { "value": "exclusion", "label": "Exclusion" },
        { "value": "hue", "label": "Hue" },
        { "value": "saturation", "label": "Saturation" },
        { "value": "color", "label": "Colour" },
        { "value": "luminosity", "label": "Luminosity" }
      ],
      "help": "How the treatment colour mixes with the image."
    },
    {
      "id": "treatmentIntensity",
      "label": "Intensity",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "Opacity of the colour overlay."
    },
    {
      "id": "noFilter",
      "label": "No filter (show raw)",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "Show the original photo or live camera feed untouched — handy for placing just a logo / lower-third over the raw footage."
    },
    {
      "id": "showLogo",
      "label": "SUSE logo overlay",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "Overlay the SUSE logo on the result. Off by default."
    },
    {
      "id": "logoPosition",
      "label": "Logo position",
      "section": "Overlay",
      "type": "select",
      "default": "top-right",
      "showIf": { "showLogo": true },
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-right", "label": "Top right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "top", "label": "Top centre" },
        { "value": "bottom", "label": "Bottom centre" },
        { "value": "center", "label": "Centre" },
        { "value": "full", "label": "Full (watermark)" }
      ]
    },
    {
      "id": "logoStyle",
      "label": "Logo colour",
      "section": "Overlay",
      "type": "select",
      "default": "white",
      "showIf": { "showLogo": true },
      "options": [
        { "value": "white", "label": "White" },
        { "value": "green", "label": "Green" },
        { "value": "black", "label": "Black" }
      ],
      "help": "White and green read on dark or busy footage; black suits light backgrounds."
    },
    {
      "id": "logoScale",
      "label": "Logo size",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "default": 1,
      "min": 0.25,
      "max": 3,
      "step": 0.05,
      "showIf": { "showLogo": true },
      "help": "Scale the logo up or down."
    },
    {
      "id": "lowerThird",
      "label": "Lower-third name card",
      "section": "Overlay",
      "type": "boolean",
      "default": false,
      "help": "A gently-animated name card that draws in over the footage. Uses your profile name & headshot."
    },
    {
      "id": "ltTheme",
      "label": "Card style",
      "section": "Overlay",
      "type": "select",
      "default": "bar",
      "showIf": { "lowerThird": true },
      "options": [
        { "value": "bar", "label": "SUSE brand bar" },
        { "value": "minimal", "label": "Minimal" },
        { "value": "glass", "label": "Glass" }
      ]
    },
    {
      "id": "ltPosition",
      "label": "Card position",
      "section": "Overlay",
      "type": "select",
      "default": "left",
      "showIf": { "lowerThird": true },
      "options": [
        { "value": "left", "label": "Bottom left" },
        { "value": "center", "label": "Bottom centre" },
        { "value": "right", "label": "Bottom right" }
      ]
    },
    {
      "id": "firstname",
      "label": "First name",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "bindToProfile": "firstname",
      "showIf": { "lowerThird": true }
    },
    {
      "id": "lastname",
      "label": "Last name",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "bindToProfile": "lastname",
      "showIf": { "lowerThird": true }
    },
    {
      "id": "title",
      "label": "Role / subtitle",
      "section": "Overlay",
      "type": "text",
      "default": "",
      "showIf": { "lowerThird": true },
      "help": "Optional line below the name — e.g. a role or event."
    },
    {
      "id": "nameWeight",
      "label": "Name weight",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "showIf": { "lowerThird": true },
      "help": "Font weight of the name line (100 Thin → 900 Black)."
    },
    {
      "id": "subtitleWeight",
      "label": "Subtitle weight",
      "section": "Overlay",
      "type": "number",
      "display": "slider",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 500,
      "showIf": { "lowerThird": true },
      "help": "Font weight of the role / subtitle line (100 Thin → 900 Black)."
    },
    {
      "id": "ltHeadshot",
      "label": "Headshot (optional)",
      "section": "Overlay",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "showIf": { "lowerThird": true },
      "help": "Defaults to your profile headshot. Pick or upload another to override."
    }
  ],
  "hooks": {
    "onInit": true,
    "onInput": true,
    "onFrame": true,
    "beforeExport": true
  }
}
