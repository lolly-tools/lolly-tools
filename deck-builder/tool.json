{
  "id": "deck-builder",
  "name": "Deck Builder",
  "description": "Build a slide deck with a live on-canvas editor — edit text, colours and images directly on each slide.",
  "a11yLabel": "Slide deck with {{slideCount}} slides",
  "version": "1.0.0",
  "engineVersion": "^1.3.0",
  "status": "community",
  "category": "designer",
  "tags": [
    "deck",
    "slides",
    "presentation",
    "editor",
    "pptx",
    "on-canvas"
  ],
  "render": {
    "width": 1920,
    "height": 1920,
    "formats": [
      "pptx",
      "pdf",
      "mp4",
      "webm",
      "gif"
    ],
    "actions": [
      "download",
      "save"
    ],
    "dims": true,
    "printMarks": false,
    "video": {
      "wait": 0,
      "duration": 6
    },
    "layout": "deck"
  },
  "hooks": {
    "onInit": true,
    "onInput": true,
    "beforeExport": true,
    "afterExport": true
  },
  "inputs": [
    {
      "id": "size",
      "label": "Deck size",
      "type": "select",
      "default": "wide",
      "help": "One size for the whole deck — PowerPoint gives every slide the same size. Override it in pixels in the export bar.",
      "options": [
        {
          "value": "wide",
          "label": "16:9 · 1920 × 1080",
          "width": 1920,
          "height": 1080,
          "unit": "px"
        },
        {
          "value": "classic",
          "label": "4:3 · 1440 × 1080",
          "width": 1440,
          "height": 1080,
          "unit": "px"
        },
        {
          "value": "square",
          "label": "1:1 · 1080 × 1080",
          "width": 1080,
          "height": 1080,
          "unit": "px"
        },
        {
          "value": "story",
          "label": "9:16 · 1080 × 1920",
          "width": 1080,
          "height": 1920,
          "unit": "px"
        }
      ]
    },
    {
      "id": "transition",
      "label": "Transition",
      "type": "select",
      "default": "none",
      "section": "Animation",
      "help": "Animation is OFF by default (None) — the deck sits still. Pick a transition to make slides animate in; only GIF, MP4 and WebM carry the motion (PowerPoint and PDF are always still).",
      "options": [
        {
          "value": "none",
          "label": "None (static)"
        },
        {
          "value": "cut",
          "label": "Cut"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "slide",
          "label": "Slide"
        },
        {
          "value": "zoom",
          "label": "Zoom"
        }
      ]
    },
    {
      "id": "transitionSpeed",
      "label": "Transition length",
      "type": "number",
      "display": "slider",
      "section": "Animation",
      "min": 0.1,
      "max": 1.5,
      "step": 0.05,
      "default": 0.5,
      "help": "Seconds each slide takes to arrive. A fade takes the whole length; a slide or zoom glides over it while the opacity snaps in, which keeps GIF/MP4 exports crisp."
    },
    {
      "id": "slideDuration",
      "label": "Seconds per slide",
      "type": "number",
      "display": "slider",
      "section": "Animation",
      "min": 0.5,
      "max": 20,
      "step": 0.5,
      "default": 3,
      "help": "How long each slide holds before the next one arrives. This plus the transitions is the length of the exported clip."
    },
    {
      "id": "loop",
      "label": "Loop",
      "type": "select",
      "default": "loop",
      "section": "Animation",
      "help": "How many times the deck plays in the GIF/MP4.",
      "options": [
        {
          "value": "loop",
          "label": "Forever"
        },
        {
          "value": "once",
          "label": "Play once"
        }
      ]
    },
    {
      "id": "focusSlide",
      "label": "Pause on slide",
      "type": "number",
      "display": "slider",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 0,
      "help": "0 plays the whole deck in the preview. Set a slide number to hold it there while you edit — exports still play."
    },
    {
      "id": "theme",
      "label": "Deck theme",
      "type": "select",
      "default": "auto",
      "section": "Brand",
      "help": "The deck's colour scheme, derived from your brand tokens. Each slide can override it.",
      "options": [
        {
          "value": "auto",
          "label": "Brand (light)"
        },
        {
          "value": "light",
          "label": "Light"
        },
        {
          "value": "dark",
          "label": "Dark"
        },
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ]
    },
    {
      "id": "pageNumbers",
      "label": "Page numbers",
      "type": "boolean",
      "default": true,
      "section": "Brand",
      "help": "Show a slide number in the bottom-right of every slide."
    },
    {
      "id": "brandLogo",
      "label": "Brand logo",
      "type": "boolean",
      "default": true,
      "section": "Brand",
      "help": "Place your brand logo in the bottom-left of every slide, picking the light or dark variant to suit each background."
    },
    {
      "id": "fitText",
      "label": "Shrink text to fit",
      "type": "boolean",
      "default": true,
      "section": "Text",
      "help": "On by default: when a slide's text outgrows the room it has, scale the whole text block down until it fits instead of letting it spill or crowd out the images. Never grows text past its authored size. Any slide can override it."
    },
    {
      "id": "typeControls",
      "label": "Custom typography",
      "type": "boolean",
      "default": false,
      "section": "Style",
      "help": "Turn on per-element type controls. Pick an element chip to set its size, weight and brand font — applied across every slide (layout and freeform), on top of the automatic shrink-to-fit."
    },
    {
      "id": "h1On",
      "label": "H1",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise the slide title and any # heading."
    },
    {
      "id": "h2On",
      "label": "H2",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise ## subheadings."
    },
    {
      "id": "h3On",
      "label": "H3",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise ### subheadings."
    },
    {
      "id": "ulOn",
      "label": "Bullets",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise - bullet lists."
    },
    {
      "id": "olOn",
      "label": "Numbered",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise 1. numbered lists."
    },
    {
      "id": "quoteOn",
      "label": "Quote",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
