      "help": "Customise > quoted blocks."
    },
    {
      "id": "codeOn",
      "label": "Code",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise fenced ``` code blocks and inline `code`."
    },
    {
      "id": "tableOn",
      "label": "Table",
      "type": "boolean",
      "display": "pill",
      "default": false,
      "section": "Style",
      "showIf": {
        "typeControls": true
      },
      "help": "Customise | pipe | tables |."
    },
    {
      "id": "h1Size",
      "label": "Title / H1 size",
      "type": "number",
      "display": "slider",
      "section": "Style",
